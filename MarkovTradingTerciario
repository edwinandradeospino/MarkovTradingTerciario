        #region Creacion

        private void CrearNuevoTerciario(string dir)
        {
            _baseTerc    = (dir == "ALCISTA")
                ? _baseTerc + _alturaTerciario
                : _baseTerc - _alturaTerciario;
            _dirTercActivo = dir;
            ResetAcumuladoresTerc();
        }

        private void CrearNuevoSecundario(string dir)
        {
            _baseSec     = (dir == "ALCISTA")
                ? _baseSec + _alturaSecundario
                : _baseSec - _alturaSecundario;
            _dirSecActivo = dir;
            ResetAcumuladoresSec();
            _etiqSecActivo = "";
        }

        private void CrearNuevoPrimario(string dir)
        {
            _basePrim    = (dir == "ALCISTA")
                ? _basePrim + _alturaPrim
                : _basePrim - _alturaPrim;
            _dirPrimActivo = dir;
            ResetAcumuladoresPrim();
            _etiqPrimActivo = "";
        }

