        // ════════════════════════════════════════════════════════════════════
        // MÁQUINA DE SEÑAL: TRIGGER → CONFIRM → ENTRADA
        // ════════════════════════════════════════════════════════════════════
        #region Señal

        private void ProcesarEtiquetaTerciario(string etiq, double fnDisplay)
        {
            if (!_esperandoConfirm)
            {
                if (etiq.Contains("DIVERGENTE_FUERTE"))
                {
                    _etiqTrigger      = etiq;
                    _fnDisplayTrigger = fnDisplay;
                    _esperandoConfirm = true;
                    _etiqPrimEnTrigger = _etiqPrimActivo;
                    _etiqSecEnTrigger  = _etiqSecActivo;

                    if (MostrarBloques)
                        Print("   🟠 TRIGGER: " + _etiqTrigger
                            + " FN_D=" + fnDisplay.ToString("F1")
                            + " | Prim=" + _etiqPrimEnTrigger
                            + " Sec="   + _etiqSecEnTrigger);
                }
                return;
            }

            bool esConfirmValido = etiq.EndsWith("FUERTE") && !etiq.Contains("DIVERGENTE");

            if (esConfirmValido)
            {
                if (MostrarBloques)
                    Print("   🟢 CONFIRM: " + etiq + " → Evaluando señal...");
                EvaluarSenales(etiq);
                _esperandoConfirm = false;
                _etiqTrigger      = "";
                _fnDisplayTrigger = 0;
            }
            else if (etiq.Contains("DIVERGENTE_FUERTE"))
            {
                // [FIX-B2] Nuevo trigger reemplaza al anterior
                _etiqTrigger      = etiq;
                _fnDisplayTrigger = fnDisplay;
                _etiqPrimEnTrigger = _etiqPrimActivo;
                _etiqSecEnTrigger  = _etiqSecActivo;

                if (MostrarBloques)
                    Print("   🟠 TRIGGER reemplazado: " + _etiqTrigger
                        + " | Prim=" + _etiqPrimEnTrigger
                        + " Sec="   + _etiqSecEnTrigger);
            }
            else
            {
                if (MostrarBloques)
                    Print("   ⏳ Intermedio ignorado (" + etiq + ") — siguiendo espera confirm");
            }
        }

        private void EvaluarSenales(string etiqConfirm)
        {
            if (_reglas == null || _reglas.Count == 0)    return;
            if (string.IsNullOrEmpty(_etiqPrimEnTrigger)) return;
            if (string.IsNullOrEmpty(_etiqSecEnTrigger))  return;
            if (string.IsNullOrEmpty(_etiqTrigger))       return;
            if (!DentroDeHorario())                       return;
            if (Position.MarketPosition != MarketPosition.Flat) return;

            foreach (var regla in _reglas)
            {
                if (!ListaContiene(regla.PrimarioCoherencia,   _etiqPrimEnTrigger)) continue;
                if (!ListaContiene(regla.SecundarioCoherencia, _etiqSecEnTrigger))  continue;
                if (!ListaContiene(regla.TriggerCoherencia,    _etiqTrigger))       continue;
                if (!ListaContiene(regla.ConfirmCoherencia,    etiqConfirm))        continue;

                if (regla.FnTriggerMinAbs > 0 &&
                    Math.Abs(_fnDisplayTrigger) < regla.FnTriggerMinAbs)
                {
                    if (MostrarBloques)
                        Print("   ⚠️ Filtro FN rechazado: |"
                            + _fnDisplayTrigger.ToString("F1")
                            + "| < " + regla.FnTriggerMinAbs.ToString("F1"));
                    continue;
                }

                EjecutarEntrada(regla, etiqConfirm);
                break;
            }
        }

        private void EjecutarEntrada(ReglaMarkov regla, string etiqConfirm)
        {
            Print("════════════════════════════════════════════════════════");
            Print("📈 " + regla.Accion + " — " + regla.Nombre);
            Print("   Prim:    " + _etiqPrimEnTrigger);
            Print("   Sec:     " + _etiqSecEnTrigger);
            Print("   Trigger: " + _etiqTrigger + " (FN_D=" + _fnDisplayTrigger.ToString("F1") + ")");
            Print("   Confirm: " + etiqConfirm);
            Print("   Precio:  " + Close[0].ToString("F2"));
            Print("════════════════════════════════════════════════════════");

            if (regla.Accion == "COMPRAR")
                EnterLong(MaxContratos, NombreLong);
            else
                EnterShort(MaxContratos, NombreShort);
        }

