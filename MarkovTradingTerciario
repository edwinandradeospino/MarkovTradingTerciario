        #region Carga

        private void CargarUmbralesDesdeMetadata()
        {
            string rutaMeta = Path.Combine(RutaJsonDir, "metadata.json");
            if (!File.Exists(rutaMeta))
            {
                Print("[MARKOV] metadata.json no encontrado — usando fallbacks UI");
                return;
            }
            try
            {
                string txt = File.ReadAllText(rutaMeta);

                // Intentar leer "umbrales_por_nivel" (v5.1+)
                int idxPorNivel = txt.IndexOf("\"umbrales_por_nivel\"");
                if (idxPorNivel >= 0)
                {
                    int blkIni = txt.IndexOf('{', idxPorNivel);
                    int blkFin = CierreObjeto(txt, blkIni);
                    string blk = txt.Substring(blkIni, blkFin - blkIni + 1);

                    // Terciario
                    int iTer = blk.IndexOf("\"terciario\"");
                    if (iTer >= 0)
                    {
                        int s = blk.IndexOf('{', iTer); int e = CierreObjeto(blk, s);
                        string sub = blk.Substring(s, e - s + 1);
                        _umbralFuerteTerc = Math.Abs(LeerDouble(sub, "\"umbral_fuerte\""));
                        _umbralDivTerc    = Math.Abs(LeerDouble(sub, "\"umbral_divergente\""));
                    }
                    // Secundario
                    int iSec = blk.IndexOf("\"secundario\"");
                    if (iSec >= 0)
                    {
                        int s = blk.IndexOf('{', iSec); int e = CierreObjeto(blk, s);
                        string sub = blk.Substring(s, e - s + 1);
                        _umbralFuerteSec = Math.Abs(LeerDouble(sub, "\"umbral_fuerte\""));
                        _umbralDivSec    = Math.Abs(LeerDouble(sub, "\"umbral_divergente\""));
                    }
                    // Primario
                    int iPrim = blk.IndexOf("\"primario\"");
                    if (iPrim >= 0)
                    {
                        int s = blk.IndexOf('{', iPrim); int e = CierreObjeto(blk, s);
                        string sub = blk.Substring(s, e - s + 1);
                        _umbralFuertePrim = Math.Abs(LeerDouble(sub, "\"umbral_fuerte\""));
                        _umbralDivPrim    = Math.Abs(LeerDouble(sub, "\"umbral_divergente\""));
                    }

                    Print("[MARKOV] Umbrales por nivel cargados de metadata.json (v5.1+):");
                    Print(string.Format("   Terc  → Fuerte={0:F1}  Div={1:F1}", _umbralFuerteTerc, _umbralDivTerc));
                    Print(string.Format("   Sec   → Fuerte={0:F1}  Div={1:F1}", _umbralFuerteSec,  _umbralDivSec));
                    Print(string.Format("   Prim  → Fuerte={0:F1}  Div={1:F1}", _umbralFuertePrim, _umbralDivPrim));
                    return;
                }

                // Fallback: leer "umbrales_estrategia" (metadata v5.0 — solo terciario)
                int idxLeg = txt.IndexOf("\"umbrales_estrategia\"");
                if (idxLeg >= 0)
                {
                    int ini = txt.IndexOf('{', idxLeg);
                    int fin = CierreObjeto(txt, ini);
                    string bl = txt.Substring(ini, fin - ini + 1);

                    double fuerteRaw = LeerDouble(bl, "\"umbral_fuerte\"");
                    double divRaw    = LeerDouble(bl, "\"umbral_divergente\"");

                    // Aplicar solo al terciario; Sec y Prim quedan en fallback UI
                    _umbralFuerteTerc = Math.Abs(fuerteRaw);
                    _umbralDivTerc    = Math.Abs(divRaw);

                    Print("[MARKOV] AVISO: metadata.json es v5.0 (umbrales_estrategia).");
                    Print("   Solo se actualizaron umbrales del TERCIARIO.");
                    Print("   Sec y Prim usan fallbacks UI. Regenerar con trainer v5.1+.");
                    Print(string.Format("   Terc  → Fuerte={0:F1}  Div={1:F1}", _umbralFuerteTerc, _umbralDivTerc));
                    Print(string.Format("   Sec   → Fuerte={0:F1}  (fallback)", _umbralFuerteSec));
                    Print(string.Format("   Prim  → Fuerte={0:F1}  (fallback)", _umbralFuertePrim));
                }
            }
            catch (Exception ex)
            {
                Print("[MARKOV] Error leyendo metadata: " + ex.Message + " — usando fallbacks UI");
            }
        }

        private void CargarReglas()
        {
            _reglas = new List<ReglaMarkov>();
            string ruta = Path.Combine(RutaJsonDir, "nivel_terciario_config.json");
            if (!File.Exists(ruta)) { Print("[MARKOV] ERROR: no encontrado " + ruta); return; }

            try
            {
                string json   = File.ReadAllText(ruta);
                var    loader = new MarkovConfigLoader();
                var    dtos   = loader.CargarReglasTerciario(json);

                foreach (var d in dtos)
                {
                    _reglas.Add(new ReglaMarkov
                    {
                        Id                   = d.Id,
                        Nombre               = d.Nombre,
                        Accion               = d.Accion,
                        PrimarioCoherencia   = d.PrimarioCoherencia,
                        SecundarioCoherencia = d.SecundarioCoherencia,
                        TriggerCoherencia    = d.TriggerCoherencia,
                        ConfirmCoherencia    = d.ConfirmCoherencia,
                        FnTriggerMinAbs      = d.FnTriggerMinAbs,
                    });
                }
                Print("[MARKOV] Reglas cargadas: " + _reglas.Count);
                Print("[MARKOV] Lógica: TRIGGER=DIV_FUERTE → CONFIRM=FUERTE → ENTRADA");
                Print("[MARKOV] SL=" + StopLossInicialPts + "pts  TP1=" + TakeProfit1Pts
                    + "pts  TP2=" + TakeProfit2Pts + "pts");
            }
            catch (Exception ex)
            {
                Print("[MARKOV] ERROR cargando reglas: " + ex.Message);
            }
        }

