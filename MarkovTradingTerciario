        // ════════════════════════════════════════════════════════════════════
        #region Acumulacion

        private void AcumularEnSecundario(string dirHijo, double fbHijo)
        {
            if (dirHijo == "ALCISTA") { _sumAlcSec += fbHijo; _cntAlcSec++; }
            else                      { _sumBajSec += fbHijo; _cntBajSec++; }
        }

        private void AcumularEnPrimario(string dirHijo, double fbHijo)
        {
            if (dirHijo == "ALCISTA") { _sumAlcPrim += fbHijo; _cntAlcPrim++; }
            else                      { _sumBajPrim += fbHijo; _cntBajPrim++; }
        }

        private void ActualizarEtiqSecActivo()
        {
            double fn        = CalcularFN(_cntAlcSec, _sumAlcSec, _cntBajSec, _sumBajSec);
            double fnDisplay = Math.Round(fn * 10, 2);
            _etiqSecActivo   = DeterminarEtiqueta(_dirSecActivo, fnDisplay);
        }

        private void ActualizarEtiqPrimActivo()
        {
            double fn        = CalcularFN(_cntAlcPrim, _sumAlcPrim, _cntBajPrim, _sumBajPrim);
            double fnDisplay = Math.Round(fn * 10, 2);
            _etiqPrimActivo  = DeterminarEtiqueta(_dirPrimActivo, fnDisplay);
        }

        #endregion

        // ════════════════════════════════════════════════════════════════════
        // MÁQUINA DE SEÑAL: TRIGGER → CONFIRM → ENTRADA
        // ════════════════════════════════════════════════════════════════════
        #region Señal

        private void ProcesarEtiquetaTerciario(string etiq, double fnDisplay)
        {
            if (!_esperandoConfirm)
            {
                // ── PASO 1: ¿Es un TRIGGER? ──────────────────────────────
                if (etiq.Contains("DIVERGENTE_FUERTE"))
                {
                    _etiqTrigger      = etiq;
                    _fnDisplayTrigger = fnDisplay;
                    _esperandoConfirm = true;

                    // [FIX-D5] Congelar contexto activo en el momento del trigger
                    _etiqPrimEnTrigger = _etiqPrimActivo;
                    _etiqSecEnTrigger  = _etiqSecActivo;

                    if (MostrarBloques)
                        Print("   🟠 TRIGGER: " + _etiqTrigger
                            + " FN_D=" + fnDisplay.ToString("F1")
                            + " | Prim=" + _etiqPrimEnTrigger
                            + " Sec="   + _etiqSecEnTrigger);
                }
                return;
            }

            // ── PASO 2: Esperando CONFIRM ─────────────────────────────────
            bool esConfirmValido = etiq.EndsWith("FUERTE") && !etiq.Contains("DIVERGENTE");

            if (esConfirmValido)
            {
                // CONFIRM recibido → evaluar señal
                if (MostrarBloques)
                    Print("   🟢 CONFIRM: " + etiq + " → Evaluando señal...");

                EvaluarSenales(etiq);

                // Limpiar estado
                _esperandoConfirm = false;
                _etiqTrigger      = "";
                _fnDisplayTrigger = 0;
            }
            else if (etiq.Contains("DIVERGENTE_FUERTE"))
            {
                // [FIX-B2] Nuevo DIVERGENTE_FUERTE reemplaza al anterior trigger
                _etiqTrigger      = etiq;
                _fnDisplayTrigger = fnDisplay;

                // [FIX-D5] Actualizar contexto congelado
                _etiqPrimEnTrigger = _etiqPrimActivo;
                _etiqSecEnTrigger  = _etiqSecActivo;

                if (MostrarBloques)
                    Print("   🟠 TRIGGER reemplazado: " + _etiqTrigger
                        + " | Prim=" + _etiqPrimEnTrigger
                        + " Sec="   + _etiqSecEnTrigger);
            }
            // [FIX-B2] Cualquier otra etiqueta (COHERENTE, DEBIL) → NO cancelar.
            //          Seguir esperando el confirm.
            else
            {
                if (MostrarBloques)
                    Print("   ⏳ Intermedio ignorado (" + etiq + ") — siguiendo espera confirm");
            }
        }

        private void EvaluarSenales(string etiqConfirm)
        {
            if (_reglas == null || _reglas.Count == 0)     return;
            if (string.IsNullOrEmpty(_etiqPrimEnTrigger))  return;
            if (string.IsNullOrEmpty(_etiqSecEnTrigger))   return;
            if (string.IsNullOrEmpty(_etiqTrigger))        return;
            if (!DentroDeHorario())                        return;
            if (Position.MarketPosition != MarketPosition.Flat) return;

            foreach (var regla in _reglas)
            {
                // [FIX-D5] Usar contexto congelado al momento del trigger
                if (!ListaContiene(regla.PrimarioCoherencia,   _etiqPrimEnTrigger)) continue;
                if (!ListaContiene(regla.SecundarioCoherencia, _etiqSecEnTrigger))  continue;
                if (!ListaContiene(regla.TriggerCoherencia,    _etiqTrigger))       continue;
                if (!ListaContiene(regla.ConfirmCoherencia,    etiqConfirm))        continue;

                // Filtro FN del trigger
                if (regla.FnTriggerMinAbs > 0 &&
                    Math.Abs(_fnDisplayTrigger) < regla.FnTriggerMinAbs)
                {
                    if (MostrarBloques)
                        Print("   ⚠️ Filtro FN rechazado: |"
                            + _fnDisplayTrigger.ToString("F1")
                            + "| < " + regla.FnTriggerMinAbs.ToString("F1"));
                    continue;
                }

                EjecutarEntrada(regla, etiqConfirm);
                break;
            }
        }

        private void EjecutarEntrada(ReglaMarkov regla, string etiqConfirm)
        {
            Print("════════════════════════════════════════════════════════");
            Print("📈 " + regla.Accion + " — " + regla.Nombre);
            Print("   Prim:    " + _etiqPrimEnTrigger);
            Print("   Sec:     " + _etiqSecEnTrigger);
            Print("   Trigger: " + _etiqTrigger + " (FN_D=" + _fnDisplayTrigger.ToString("F1") + ")");
            Print("   Confirm: " + etiqConfirm);
            Print("   Precio:  " + Close[0].ToString("F2"));
            Print("════════════════════════════════════════════════════════");

            if (regla.Accion == "COMPRAR")
                EnterLong(MaxContratos, NombreLong);
            else
                EnterShort(MaxContratos, NombreShort);
        }

        #endregion

        // ════════════════════════════════════════════════════════════════════
        // CÁLCULOS FN Y CLASIFICACIÓN
        // ════════════════════════════════════════════════════════════════════
        #region Calculos

        private double CalcularFN(int cA, double sA, int cB, double sB)
        {
            double compAlc = (cA > 0) ? sA / cA : 0;
            double compBaj = (cB > 0) ? sB / cB : 0;
            return compAlc + compBaj;
        }

        // [FIX-D4] Clasificación idéntica al exportador E1:
        //   ALCISTA: > umbFuerte → FUERTE
        //            > 0         → COHERENTE
        //            > -umbDiv   → DIV_DEBIL
        //            else        → DIV_FUERTE
        //   BAJISTA: < -umbFuerte → FUERTE
        //            < 0          → COHERENTE
        //            < umbDiv     → DIV_DEBIL   (equiv. < -(-umbDiv))
        //            else         → DIV_FUERTE
        private string DeterminarEtiqueta(string dir, double fnDisplay)
        {
            double umbFuerte = _umbralFuerteAbs;   // positivo, ej: 115
            double umbDiv    = _umbralDivAbs;       // positivo, ej: 53.8

            if (dir == "ALCISTA")
            {
                if (fnDisplay >  umbFuerte) return "ALCISTA_FUERTE";
                if (fnDisplay >  0)         return "ALCISTA_COHERENTE";
                if (fnDisplay > -umbDiv)    return "ALCISTA_DIVERGENTE_DEBIL";
                return                             "ALCISTA_DIVERGENTE_FUERTE";
            }
            else
            {
                if (fnDisplay < -umbFuerte) return "BAJISTA_FUERTE";
                if (fnDisplay <  0)         return "BAJISTA_COHERENTE";
                if (fnDisplay <  umbDiv)    return "BAJISTA_DIVERGENTE_DEBIL";
                return                             "BAJISTA_DIVERGENTE_FUERTE";
            }
        }

        #endregion

