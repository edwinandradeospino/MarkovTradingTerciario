        #region Riesgo

        protected override void OnExecutionUpdate(Execution execution, string executionId,
            double price, int quantity, MarketPosition marketPosition,
            string orderId, DateTime time)
        {
            if (execution.Order == null) return;
            string     nombre = execution.Order.Name;
            OrderState st     = execution.Order.OrderState;

            if ((nombre == NombreLong || nombre == NombreShort) &&
                (st == OrderState.Filled || st == OrderState.PartFilled))
            {
                _precioEntrada = price;
                _direccionOp   = (nombre == NombreLong) ? "LONG" : "SHORT";
                _estadoOp      = EstadoOp.Abierta;
                Print("✅ Entrada @ " + price.ToString("F2")
                    + " | Dir: " + _direccionOp
                    + " | Contratos: " + MaxContratos);
                ColocarOrdenesFase1();
            }
        }

        protected override void OnPositionUpdate(Position position, double averagePrice,
            int quantity, MarketPosition marketPosition)
        {
            if (_estadoOp == EstadoOp.Abierta &&
                MaxContratos == 2 &&
                position.MarketPosition != MarketPosition.Flat &&
                position.Quantity == 1)
            {
                Print("🎯 TP1 alcanzado — Activando Breakeven...");
                ActivarBreakeven();
            }

            if (position.MarketPosition == MarketPosition.Flat && _estadoOp != EstadoOp.Flat)
            {
                Print("🏁 Posición cerrada.");
                _estadoOp = EstadoOp.Flat;
            }
        }

        private void ColocarOrdenesFase1()
        {
            int slTicks  = StopLossInicialPts * 4;
            int tp1Ticks = TakeProfit1Pts     * 4;
            int tp2Ticks = TakeProfit2Pts     * 4;

            string nombre = (_direccionOp == "LONG") ? NombreLong : NombreShort;

            SetStopLoss(nombre, CalculationMode.Ticks, slTicks, false);

            // MaxContratos=2 → TP1 para el primer contrato (el segundo se gestiona vía breakeven)
            // MaxContratos=1 → TP1 también (contrato único con el objetivo conservador)
            // Si quieres TP2 con 1 contrato, cambia tp1Ticks por tp2Ticks en la línea siguiente
            SetProfitTarget(nombre, CalculationMode.Ticks, tp1Ticks);

            double slRef  = (_direccionOp == "LONG")
                ? _precioEntrada - StopLossInicialPts : _precioEntrada + StopLossInicialPts;
            double tp1Ref = (_direccionOp == "LONG")
                ? _precioEntrada + TakeProfit1Pts     : _precioEntrada - TakeProfit1Pts;
            double tp2Ref = (_direccionOp == "LONG")
                ? _precioEntrada + TakeProfit2Pts     : _precioEntrada - TakeProfit2Pts;

            Print("   SL @ " + slRef.ToString("F2")
                + " | TP1 @ " + tp1Ref.ToString("F2")
                + " | TP2 @ " + tp2Ref.ToString("F2") + " (post-BE)");
        }

        private void ActivarBreakeven()
        {
            _estadoOp = EstadoOp.BreakevenActivo;
            string nombre = (_direccionOp == "LONG") ? NombreLong : NombreShort;

            double bePrecio = (_direccionOp == "LONG")
                ? _precioEntrada + (BreakevenTicks * TickSize)
                : _precioEntrada - (BreakevenTicks * TickSize);

            SetStopLoss(nombre, CalculationMode.Price, bePrecio, false);
            SetProfitTarget(nombre, CalculationMode.Ticks, TakeProfit2Pts * 4);

            double tp2Ref = (_direccionOp == "LONG")
                ? _precioEntrada + TakeProfit2Pts
                : _precioEntrada - TakeProfit2Pts;

            Print("   🔒 BE @ " + bePrecio.ToString("F2")
                + " | TP2 @ " + tp2Ref.ToString("F2"));
        }

