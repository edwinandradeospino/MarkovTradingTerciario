        // ════════════════════════════════════════════════════════════════════
        // [FIX-U1 + FIX-U2] CÁLCULO FN Y CLASIFICACIÓN POR NIVEL
        // ════════════════════════════════════════════════════════════════════
        #region Calculos

        private double CalcularFN(int cA, double sA, int cB, double sB)
        {
            double compAlc = (cA > 0) ? sA / cA : 0;
            double compBaj = (cB > 0) ? sB / cB : 0;
            return compAlc + compBaj;
        }

        // [FIX-U1] Recibe el nivel para aplicar el umbral correcto.
        // [FIX-U2] fnDisplay <= 0 en BAJISTA → COHERENTE (corrige edge case fnDisplay=0).
        //
        // Lógica idéntica al exportador MultiBricksDataExporterNeta:
        //   ALCISTA: > umbFuerte → FUERTE
        //            > 0         → COHERENTE
        //            > -umbDiv   → DIV_DEBIL
        //            else        → DIV_FUERTE
        //   BAJISTA: < -umbFuerte → FUERTE
        //            <= 0         → COHERENTE   ← FIX-U2: era < 0
        //            < umbDiv     → DIV_DEBIL
        //            else         → DIV_FUERTE
        private string DeterminarEtiqueta(string dir, double fnDisplay, Nivel nivel)
        {
            // [FIX-U1] Seleccionar umbrales según el nivel
            double umbFuerte, umbDiv;
            switch (nivel)
            {
                case Nivel.Secundario:
                    umbFuerte = _umbralFuerteSec;
                    umbDiv    = _umbralDivSec;
                    break;
                case Nivel.Primario:
                    umbFuerte = _umbralFuertePrim;
                    umbDiv    = _umbralDivPrim;
                    break;
                default: // Terciario
                    umbFuerte = _umbralFuerteTerc;
                    umbDiv    = _umbralDivTerc;
                    break;
            }

            if (dir == "ALCISTA")
            {
                if (fnDisplay >  umbFuerte) return "ALCISTA_FUERTE";
                if (fnDisplay >  0)         return "ALCISTA_COHERENTE";
                if (fnDisplay > -umbDiv)    return "ALCISTA_DIVERGENTE_DEBIL";
                return                             "ALCISTA_DIVERGENTE_FUERTE";
            }
            else
            {
                if (fnDisplay < -umbFuerte) return "BAJISTA_FUERTE";
                if (fnDisplay <= 0)         return "BAJISTA_COHERENTE";   // [FIX-U2] era < 0
                if (fnDisplay <  umbDiv)    return "BAJISTA_DIVERGENTE_DEBIL";
                return                             "BAJISTA_DIVERGENTE_FUERTE";
            }
        }

