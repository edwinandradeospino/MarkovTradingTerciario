        // ════════════════════════════════════════════════════════════════════
        // LOOP PRINCIPAL — [FIX-D1] Escape JERÁRQUICO
        // ════════════════════════════════════════════════════════════════════
        #region OnBarUpdate

        protected override void OnBarUpdate()
        {
            if (BarsInProgress != 0) return;
            if (CurrentBar < 2)      return;

            if (!_inicializado)
            {
                _basePrim = _baseSec = _baseTerc = Close[0];
                _inicializado = true;

                _alturaPrim       = PrimarioNTicks   * TickSize;
                _alturaSecundario = SecundarioNTicks * TickSize;
                _alturaTerciario  = TerciarioNTicks  * TickSize;
                _escapePrim       = PrimarioEscape   * TickSize;
                _escapeSecundario = SecundarioEscape * TickSize;
                _escapeTerciario  = TerciarioEscape  * TickSize;

                Print("[MARKOV] Inicializado @ " + Close[0].ToString("F2"));
                return;
            }

            double high = High[0];
            double low  = Low[0];

            bool   esAlc  = Close[0] >= Open[0];
            double fbVela = esAlc
                ?  (high - low) / TickSize
                : -(high - low) / TickSize;
            _fbBrutoTerc += fbVela;
            if (esAlc) { _sumAlcTerc += fbVela; _cntAlcTerc++; }
            else       { _sumBajTerc += fbVela; _cntBajTerc++; }

            double supTerc = _baseTerc + (_alturaTerciario  / 2) + _escapeTerciario;
            double infTerc = _baseTerc - (_alturaTerciario  / 2) - _escapeTerciario;
            double supSec  = _baseSec  + (_alturaSecundario / 2) + _escapeSecundario;
            double infSec  = _baseSec  - (_alturaSecundario / 2) - _escapeSecundario;
            double supPrim = _basePrim + (_alturaPrim       / 2) + _escapePrim;
            double infPrim = _basePrim - (_alturaPrim       / 2) - _escapePrim;

            _escapeSuperiorEnCurso = false;

            if (high > supPrim || low < infPrim)
            {
                _escapeSuperiorEnCurso = true;
                string dir = (high > supPrim) ? "ALCISTA" : "BAJISTA";
                CerrarTerciarioEnCascada(dir);
                CerrarSecundarioEnCascada(dir);
                CerrarPrimario(dir);
                CrearNuevoPrimario(dir);
                CrearNuevoSecundario(dir);
                CrearNuevoTerciario(dir);
            }
            else if (high > supSec || low < infSec)
            {
                _escapeSuperiorEnCurso = true;
                string dir = (high > supSec) ? "ALCISTA" : "BAJISTA";
                CerrarTerciarioEnCascada(dir);
                CerrarSecundario(dir);
                CrearNuevoSecundario(dir);
                CrearNuevoTerciario(dir);
            }
            else if (high > supTerc || low < infTerc)
            {
                string dir = (high > supTerc) ? "ALCISTA" : "BAJISTA";
                CerrarTerciario(dir);
                CrearNuevoTerciario(dir);
            }

            if (MostrarDiagnostico && CurrentBar % 500 == 0)
                ImprimirDiagnostico();
        }

