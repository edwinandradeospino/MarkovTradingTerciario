        // ════════════════════════════════════════════════════════════════════
        // CIERRE DE BLOQUES
        // ════════════════════════════════════════════════════════════════════
        #region Cierre

        // Cierre de terciario en escape PROPIO (genera señal)
        private void CerrarTerciario(string dir)
        {
            double fn        = CalcularFN(_cntAlcTerc, _sumAlcTerc, _cntBajTerc, _sumBajTerc);
            double fnDisplay = Math.Round(fn * 10, 2);

            // [FIX-D4] Clasificación con zona COHERENTE correcta
            string etiq = DeterminarEtiqueta(dir, fnDisplay);

            // Acumular en secundario
            AcumularEnSecundario(dir, _fbBrutoTerc);

            if (MostrarBloques)
                Print("🟪 Terc → " + etiq
                    + " | FN_D: " + fnDisplay.ToString("F1")
                    + (_esperandoConfirm ? " [ESPERANDO CONFIRM]" : ""));

            // Recalcular etiqueta del secundario activo
            ActualizarEtiqSecActivo();

            // Evaluar máquina de señal
            ProcesarEtiquetaTerciario(etiq, fnDisplay);

            ResetAcumuladoresTerc();
        }

        // Cierre de terciario dentro de una cascada de escape superior
        // No actualiza la señal porque el contexto se va a resetear
        private void CerrarTerciarioEnCascada(string dir)
        {
            double fn        = CalcularFN(_cntAlcTerc, _sumAlcTerc, _cntBajTerc, _sumBajTerc);
            double fnDisplay = Math.Round(fn * 10, 2);
            string etiq      = DeterminarEtiqueta(dir, fnDisplay);

            // Acumular en secundario
            AcumularEnSecundario(dir, _fbBrutoTerc);

            if (MostrarBloques)
                Print("🟪 Terc (cascada) → " + etiq + " | FN_D: " + fnDisplay.ToString("F1"));

            // En cascada: cancelar cualquier trigger pendiente (contexto cambia)
            if (_esperandoConfirm)
            {
                _esperandoConfirm = false;
                _etiqTrigger      = "";
                _fnDisplayTrigger = 0;
                if (MostrarBloques)
                    Print("   ⚠️ Trigger cancelado por escape superior");
            }

            ResetAcumuladoresTerc();
        }

        private void CerrarSecundario(string dir)
        {
            double fn        = CalcularFN(_cntAlcSec, _sumAlcSec, _cntBajSec, _sumBajSec);
            double fnDisplay = Math.Round(fn * 10, 2);
            string etiq      = DeterminarEtiqueta(dir, fnDisplay);

            // Acumular en primario con el FB del secundario
            double fbSec = _sumAlcSec + _sumBajSec;
            AcumularEnPrimario(dir, fbSec);
            ActualizarEtiqPrimActivo();

            if (MostrarBloques)
                Print("🟦 Sec → " + etiq + " | FN_D: " + fnDisplay.ToString("F1"));

            ResetAcumuladoresSec();
            _etiqSecActivo = "";
        }

        // Alias para legibilidad en cascada de primario
        private void CerrarSecundarioEnCascada(string dir) { CerrarSecundario(dir); }

        private void CerrarPrimario(string dir)
        {
            double fn        = CalcularFN(_cntAlcPrim, _sumAlcPrim, _cntBajPrim, _sumBajPrim);
            double fnDisplay = Math.Round(fn * 10, 2);
            string etiq      = DeterminarEtiqueta(dir, fnDisplay);

            if (MostrarBloques)
                Print("🟥 Prim → " + etiq + " | FN_D: " + fnDisplay.ToString("F1"));

            ResetAcumuladoresPrim();
            _etiqPrimActivo = "";
        }

