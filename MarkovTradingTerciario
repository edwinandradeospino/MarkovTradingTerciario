        #region Utilidades

        private bool DentroDeHorario()
        {
            var h   = Time[0].TimeOfDay;
            var ini = new TimeSpan(HoraInicioHH, HoraInicioMM, 0);
            var fin = new TimeSpan(HoraFinHH,    HoraFinMM,    0);
            return h >= ini && h <= fin;
        }

        private bool ListaContiene(List<string> lista, string valor)
        {
            if (lista == null || lista.Count == 0) return true;
            return lista.Contains(valor);
        }

        private double LeerDouble(string json, string clave)
        {
            int i = json.IndexOf(clave); if (i < 0) return 0;
            int c = json.IndexOf(':', i); if (c < 0) return 0;
            int s = c + 1;
            while (s < json.Length && (json[s] == ' ' || json[s] == '\n')) s++;
            int e = s;
            while (e < json.Length && (char.IsDigit(json[e]) || json[e] == '.' || json[e] == '-')) e++;
            double r;
            return double.TryParse(json.Substring(s, e - s),
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out r) ? r : 0;
        }

        private void ImprimirDiagnostico()
        {
            Print("DIAG Barra " + CurrentBar
                + " | P:"  + _etiqPrimActivo
                + " | S:"  + _etiqSecActivo
                + " | Tr:" + _etiqTrigger
                + " | Esp:" + _esperandoConfirm
                + " | Op:" + _estadoOp);
        }

