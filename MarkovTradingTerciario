    public class ReglaMarkovDTO
    {
        public string       Id                   { get; set; }
        public string       Nombre               { get; set; }
        public string       Accion               { get; set; }
        public List<string> PrimarioCoherencia   { get; set; } = new List<string>();
        public List<string> SecundarioCoherencia { get; set; } = new List<string>();
        public List<string> TriggerCoherencia    { get; set; } = new List<string>();
        public List<string> ConfirmCoherencia    { get; set; } = new List<string>();
        public double       FnTriggerMinAbs      { get; set; } = 0;
        public double       WinRate              { get; set; }
        public int          TotalSenales         { get; set; }
        public bool         Activa               { get; set; } = true;
    }

    // ════════════════════════════════════════════════════════════════════════
    // PARSER JSON MANUAL (sin Newtonsoft, compatible NT8)
    // ════════════════════════════════════════════════════════════════════════
    public class MarkovConfigLoader
    {
        public List<ReglaMarkovDTO> CargarReglasTerciario(string jsonText)
        {
            var resultado = new List<ReglaMarkovDTO>();
            int idxReglas = jsonText.IndexOf("\"reglas\"");
            if (idxReglas < 0) return resultado;

            int idxArr = jsonText.IndexOf('[', idxReglas);
            if (idxArr < 0) return resultado;

            int pos = idxArr + 1;
            while (pos < jsonText.Length)
            {
                int objIni = jsonText.IndexOf('{', pos);
                if (objIni < 0) break;

                int objFin = CierreObjeto(jsonText, objIni);
                if (objFin < 0) break;

                string obj = jsonText.Substring(objIni, objFin - objIni + 1);
                var r = ParsearRegla(obj);
                if (r != null) resultado.Add(r);

                pos = objFin + 1;
                int nB = jsonText.IndexOf('{', pos);
                int nK = jsonText.IndexOf(']', pos);
                if (nK >= 0 && (nB < 0 || nK < nB)) break;
            }
            return resultado;
        }

        private ReglaMarkovDTO ParsearRegla(string obj)
        {
            try
            {
                var r    = new ReglaMarkovDTO();
                r.Id     = Str(obj, "\"id\"");
                r.Nombre = Str(obj, "\"nombre\"");

                int ilg = obj.IndexOf("\"logica_entrada\"");
                if (ilg >= 0)
                {
                    int ls = obj.IndexOf('{', ilg);
                    int le = CierreObjeto(obj, ls);
                    r.Accion = Str(obj.Substring(ls, le - ls + 1), "\"accion\"");
                }
                if (string.IsNullOrEmpty(r.Accion))
                {
                    int ip = obj.IndexOf("\"parametros\"");
                    if (ip >= 0)
                    {
                        int ps = obj.IndexOf('{', ip);
                        int pe = CierreObjeto(obj, ps);
                        r.Accion = Str(obj.Substring(ps, pe - ps + 1), "\"accion\"");
                    }
                }

                int ic = obj.IndexOf("\"condiciones\"");
                if (ic >= 0)
                {
                    int cs = obj.IndexOf('{', ic);
                    int ce = CierreObjeto(obj, cs);
                    string co = obj.Substring(cs, ce - cs + 1);

                    r.PrimarioCoherencia   = Lista(co, "\"primario_coherencia\"");
                    r.SecundarioCoherencia = Lista(co, "\"secundario_coherencia\"");
                    r.TriggerCoherencia    = Lista(co, "\"trigger_coherencia\"");
                    r.ConfirmCoherencia    = Lista(co, "\"confirm_coherencia\"");
                    r.FnTriggerMinAbs      = Dbl(co,   "\"fn_trigger_min_abs\"");
                }

                int ie = obj.IndexOf("\"estadisticas\"");
                if (ie >= 0)
                {
                    int es = obj.IndexOf('{', ie);
                    int ee = CierreObjeto(obj, es);
                    string eo = obj.Substring(es, ee - es + 1);
                    r.WinRate      = Dbl(eo, "\"win_rate\"");
                    r.TotalSenales = (int)Dbl(eo, "\"total_observaciones\"");
                }

                r.Activa = Bool(obj, "\"activa\"");
                if (string.IsNullOrEmpty(r.Accion) || !r.Activa) return null;
                return r;
            }
            catch { return null; }
        }

        private int CierreObjeto(string t, int ini)
        {
            int d = 0;
            for (int i = ini; i < t.Length; i++)
            {
                if      (t[i] == '{') d++;
                else if (t[i] == '}') { d--; if (d == 0) return i; }
            }
            return -1;
        }

        private string Str(string j, string k)
        {
            int i = j.IndexOf(k); if (i < 0) return "";
            int c = j.IndexOf(':', i); if (c < 0) return "";
            int q1 = j.IndexOf('"', c + 1); if (q1 < 0) return "";
            int q2 = j.IndexOf('"', q1 + 1); if (q2 < 0) return "";
            return j.Substring(q1 + 1, q2 - q1 - 1);
        }

        private List<string> Lista(string j, string k)
        {
            var l  = new List<string>();
            int i  = j.IndexOf(k); if (i < 0) return l;
            int a1 = j.IndexOf('[', i);
            int a2 = j.IndexOf(']', a1);
            if (a1 < 0 || a2 < 0) return l;
            string c = j.Substring(a1 + 1, a2 - a1 - 1).Trim();
            if (c == "null" || c == "") return l;
            int p = 0;
            while (p < c.Length)
            {
                int q1 = c.IndexOf('"', p); if (q1 < 0) break;
                int q2 = c.IndexOf('"', q1 + 1); if (q2 < 0) break;
                l.Add(c.Substring(q1 + 1, q2 - q1 - 1));
                p = q2 + 1;
            }
            return l;
        }

        private double Dbl(string j, string k)
        {
            int i = j.IndexOf(k); if (i < 0) return 0;
            int c = j.IndexOf(':', i); if (c < 0) return 0;
            int s = c + 1;
            while (s < j.Length && " \n\r".IndexOf(j[s]) >= 0) s++;
            int e = s;
            while (e < j.Length && (char.IsDigit(j[e]) || j[e] == '.' || j[e] == '-')) e++;
            double r;
            return double.TryParse(j.Substring(s, e - s),
                System.Globalization.NumberStyles.Float,
                System.Globalization.CultureInfo.InvariantCulture, out r) ? r : 0;
        }

        private bool Bool(string j, string k)
        {
            int i = j.IndexOf(k); if (i < 0) return true;
            int c = j.IndexOf(':', i); if (c < 0) return true;
            int s = c + 1;
            while (s < j.Length && j[s] == ' ') s++;
            return j.Substring(s, Math.Min(4, j.Length - s)).ToLower().StartsWith("true");
        }
    }
